# Database
DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/myuta?sslmode=disable

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000
APP_ENV=development

# Optional: YouTube Data API v3 key (enables song search)
YOUTUBE_API_KEY=

# Optional: Anthropic Claude API key (enables OCR review import)
ANTHROPIC_API_KEY=

# Optional: Anthropic model used for OCR review import
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
